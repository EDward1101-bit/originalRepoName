# ============================================
# GLOBAL Environment Variables
# ============================================

SERVER_HOSTNAME=
IP=

# Supabase Configuration
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ++++++++++++++++++++++++++++++++++++++++++++
# Prosody configuration variables 
# ++++++++++++++++++++++++++++++++++++++++++++

PROSODY_DOMAIN=${SERVER_HOSTNAME}
PROSODY_ADMIN_USER=admin
# Leave empty - password set via prosodyctl
PROSODY_ADMIN_PASSWORD=

# ++++++++++++++++++++++++++++++++++++++++++++
# Backend configuration variables
# ++++++++++++++++++++++++++++++++++++++++++++

# Prosody Configuration
PROSODY_URL=http://prosody:5280

# Environment
ENVIRONMENT=development

# ++++++++++++++++++++++++++++++++++++++++++++
# Frontend configuration variables
# ++++++++++++++++++++++++++++++++++++++++++++

# API Configuration
VITE_SERVER_HOSTNAME=${SERVER_HOSTNAME}
VITE_API_URL=http://${SERVER_HOSTNAME}:8000
VITE_WS_URL=ws://${SERVER_HOSTNAME}:8000

# Supabase Configuration
VITE_SUPABASE_URL=${SUPABASE_URL}
VITE_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}

# Ollama Configuration
# Default is qwen2.5:0.5b for fast execution on CPU. Use qwen2.5:7b or similar if GPU is available.
OLLAMA_MODEL=qwen2.5:0.5b

